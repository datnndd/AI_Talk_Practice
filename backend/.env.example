# ============================================================
# AI Talk Practice - Backend Configuration
# Copy this file to backend/.env and fill in your real values
# ============================================================

# --- Provider Selection ---
ASR_PROVIDER=deepgram
LLM_PROVIDER=gemini
TTS_PROVIDER=dashscope

# --- Database ---
# Supabase PostgreSQL. Use `postgresql+asyncpg://` with the pooler or direct URL.
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# --- Auth / JWT ---
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
JWT_REFRESH_EXPIRE_MINUTES=10080

# --- OAuth ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- SMTP / Email ---
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@aitalkpractice.com

# --- API Keys ---
DASHSCOPE_API_KEY=
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_SPEECH_LANGUAGE=en-US
DICTIONARY_API_BASE_URL=https://dict.minhqnd.com

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Payment / Billing ---
FRONTEND_URL=https://your-frontend-domain.example
PAYMENT_PRO_DURATION_DAYS=30
PAYMENT_PRO_AMOUNT_USD_CENTS=9900

# --- LLM Configuration ---
LLM_MODEL=gemini-2.5-flash
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MAX_TOKENS=800
LLM_SYSTEM_PROMPT=You are a friendly and patient English conversation tutor. Help the user practice speaking English naturally. Keep responses concise (2-3 sentences). Correct major errors gently. Encourage the user to speak more.

# --- ASR Configuration ---
ASR_LANGUAGE=en
ASR_MODEL_LOCAL=small

# --- TTS Configuration ---
TTS_VOICE=Cherry
TTS_LANGUAGE=en
TTS_VOICE_LOCAL=af_heart

# --- DashScope Region ---
DASHSCOPE_REGION=intl

# --- Server ---
HOST=0.0.0.0
PORT=8000
IS_DEBUG=false

# Comma-separated values are supported by pydantic-settings env parsing in many setups,
# but when in doubt prefer setting this directly in your deployment environment.
CORS_ORIGINS=["https://your-frontend-domain.example"]
