# ============================================================
# AI Talk Practice - Backend Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Provider Selection ---
# Switch between API (cloud) and local providers
ASR_PROVIDER=dashscope          # dashscope | faster_whisper
LLM_PROVIDER=gemini             # gemini | openai
TTS_PROVIDER=dashscope          # dashscope | kokoro

# --- API Keys ---
DASHSCOPE_API_KEY=sk-xxx        # Alibaba Cloud Model Studio (for ASR/TTS API)
GEMINI_API_KEY=xxx              # Google AI Studio (for LLM)
# OPENAI_API_KEY=sk-xxx         # Optional: if using OpenAI as LLM provider

# --- LLM Configuration ---
LLM_MODEL=gemini-2.5-flash
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_SYSTEM_PROMPT=You are a friendly and patient English conversation tutor. Help the user practice speaking English naturally. Keep responses concise (2-3 sentences). Correct major errors gently. Encourage the user to speak more.

# --- ASR Configuration ---
ASR_LANGUAGE=en                 # Language code (en, zh, ja, etc.)
ASR_MODEL=qwen3-asr-flash-realtime   # DashScope model name
# ASR_MODEL_LOCAL=small               # faster-whisper model size (tiny/small/medium/large-v3)

# --- TTS Configuration ---
TTS_VOICE=Cherry                # DashScope voice name
TTS_LANGUAGE=en
# TTS_VOICE_LOCAL=af_heart       # Kokoro voice ID

# --- DashScope Region ---
DASHSCOPE_REGION=intl           # intl (Singapore) | cn (China mainland)

# --- Database ---
# Default uses local SQLite. For PostgreSQL, use: postgresql+asyncpg://user:pass@localhost:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./ai_talk_practice.db

# --- Server ---
HOST=0.0.0.0
PORT=8000
